// tests/test_align.ysu

struct AlignStruct {
    @align(64) @atomic head: I32,
    _pad_i32: I32,
    _pad1: I64,
    _pad2: I64,
    _pad3: I64,
    _pad4: I64,
    _pad5: I64,
    _pad6: I64,
    _pad7: I64,
    @align(64) @atomic tail: I32,
    _pad_i32_2: I32,
    _pad8: I64,
    _pad9: I64,
    _pad10: I64,
    _pad11: I64,
    _pad12: I64,
    _pad13: I64,
    _pad14: I64,
}

fn AlignStruct_new(head: I32, tail: I32) -> AlignStruct {
    return AlignStruct {
        head: head, _pad_i32: 0,
        _pad1: 0, _pad2: 0, _pad3: 0, _pad4: 0, _pad5: 0, _pad6: 0, _pad7: 0,
        tail: tail, _pad_i32_2: 0,
        _pad8: 0, _pad9: 0, _pad10: 0, _pad11: 0, _pad12: 0, _pad13: 0, _pad14: 0
    };
}

fn test_align(s: &mut AlignStruct) {
    s.head = 42;
    s.tail = 24;
}

fn main() {
    let s = AlignStruct_new(0, 0);
    test_align(&mut s);
    print_int(s.head);
    print_int(s.tail);
    println("");
}
